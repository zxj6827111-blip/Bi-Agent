# 本地服务端口
PORT=4173

# OpenAI / 中转站配置
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_BASE_URL=https://api.openai.com/v1

# 如果你的中转站不是标准 /v1/responses，可以填写完整接口；通常留空即可。
OPENAI_RESPONSES_URL=

# Binance 公共行情配置
BINANCE_SPOT_BASE_URL=https://data-api.binance.vision
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
# Optional comma-separated fallback endpoints. Keep empty unless your network needs them.
BINANCE_SPOT_BASE_URLS=https://data-api.binance.vision
BINANCE_FUTURES_BASE_URLS=https://fapi.binance.com
BINANCE_REQUEST_TIMEOUT_MS=8000

# 扫描参数
TOP_SYMBOLS_PER_MARKET=24
MAX_AI_SIGNALS=12
MIN_QUOTE_VOLUME=15000000
MAX_SPREAD_PERCENT=0.35
REQUEST_CONCURRENCY=6

# 全市场自动发现参数
# 注意：数值越大，请求越多，刷新越慢，也更容易触发交易所限流。
MARKET_WATCH_MAX_SYMBOLS=80
MARKET_WATCH_SIGNAL_LIMIT=30
MARKET_WATCH_AI_REVIEW_LIMIT=3
MARKET_WATCH_MIN_REFRESH_SECONDS=60
MARKET_WATCH_REQUEST_CONCURRENCY=4

# 复盘和纸面交易成本假设
# fee rate 是单边费率，例如 0.001 = 0.1%；slippage percent 是单边滑点百分比。
SPOT_FEE_RATE=0.001
FUTURES_FEE_RATE=0.0005
ASSUMED_SLIPPAGE_PERCENT=0.05

# 只有纸面验证达到这些门槛时，才认为策略具备继续观察价值。
MIN_VALIDATION_TRADES=30
MIN_VALIDATION_WIN_RATE=0.5
MIN_VALIDATION_EXPECTANCY_PERCENT=0
MAX_VALIDATION_DRAWDOWN_PERCENT=8

# Real-time direction engine
DIRECTION_ENGINE_ENABLED=true
DIRECTION_DEPTH_LIMIT=50
DIRECTION_AGG_TRADE_LIMIT=500
DIRECTION_MIN_FORMAL_EDGE=35
DIRECTION_CONTRADICTION_EDGE=25

# Formal signal paper monitor filters
FORMAL_MONITOR_OUTPUT_DIR=
FORMAL_MONITOR_CONFIRMATION_SCANS=2
FORMAL_MONITOR_CONFIRMATION_STALE_SCANS=3
FORMAL_MONITOR_CONFIRMATION_MODE=recent
FORMAL_MONITOR_SIGNAL_INTERVAL=5m
FORMAL_MONITOR_SOURCE_SIGNAL_INTERVAL=15m
FORMAL_MONITOR_CONFIRMATION_INTERVALS=1h,4h
FORMAL_MONITOR_MIN_EDGE=25
FORMAL_MONITOR_MIN_SCORE=72
FORMAL_MONITOR_MIN_VOLUME_RATIO=0.45
FORMAL_MONITOR_EXECUTION_MIN_SCORE=76
FORMAL_MONITOR_EXECUTION_MIN_EDGE=18
FORMAL_MONITOR_EXECUTION_MAX_SOFT_FAILURES=1
FORMAL_MONITOR_FILTERED_SOURCE_MIN_SCORE=70
FORMAL_MONITOR_ACCOUNT_RISK_PER_TRADE_PERCENT=0.5
FORMAL_MONITOR_MAX_PORTFOLIO_RISK_PERCENT=2.0
FORMAL_MONITOR_MAX_SAME_SIDE_OPEN=3
FORMAL_MONITOR_MAX_POSITION_SIZE_PERCENT=35
FORMAL_MONITOR_MAX_PORTFOLIO_POSITION_SIZE_PERCENT=100
FORMAL_MONITOR_MAX_SESSION_DRAWDOWN_PERCENT=8
FORMAL_MONITOR_MAX_DAILY_LOSS_PERCENT=3
FORMAL_MONITOR_REQUIRE_ENTRY_QUALITY=true
FORMAL_MONITOR_MOMENTUM_ENTRY_ENABLED=true
FORMAL_MONITOR_MOMENTUM_MIN_SCORE=84
FORMAL_MONITOR_MOMENTUM_MIN_EDGE=28
FORMAL_MONITOR_MOMENTUM_MIN_VOLUME_RATIO=1.05
FORMAL_MONITOR_MOMENTUM_MIN_LIVE_MOVE_PERCENT=0.28
FORMAL_MONITOR_MOMENTUM_MIN_CLOSED_MOVE_PERCENT=0.24
FORMAL_MONITOR_MOMENTUM_MAX_LONG_CHASE_24H_PERCENT=9
FORMAL_MONITOR_MOMENTUM_MAX_SHORT_CHASE_24H_PERCENT=9
FORMAL_MONITOR_MOMENTUM_MAX_SOFT_FAILURES=2
FORMAL_MONITOR_SCALP_MAX_HOLD_MINUTES=25
FORMAL_MONITOR_SCALP_POLL_SECONDS=5
FORMAL_MONITOR_SCALP_ALERT_MAX_CANDIDATES=16
FORMAL_MONITOR_SCALP_ALERT_MIN_MOVE_PERCENT=0.18
FORMAL_MONITOR_SCALP_ALERT_MIN_VOLUME_RATIO=1.2
FORMAL_MONITOR_SCALP_ALERT_MIN_EDGE=12
FORMAL_MONITOR_SCALP_DECISION_MIN_SCORE=80
FORMAL_MONITOR_SCALP_DECISION_MIN_EDGE=22
FORMAL_MONITOR_SCALP_DECISION_MIN_VOLUME_RATIO=1.05
FORMAL_MONITOR_SCALP_TARGET_PERCENT=0.32
FORMAL_MONITOR_SCALP_STOP_PERCENT=0.24
FORMAL_MONITOR_SCALP_MIN_NET_TARGET_PERCENT=0.08
FORMAL_MONITOR_SCALP_MIN_REWARD_RISK=0.95
FORMAL_MONITOR_SCALP_ALLOW_NO_SOURCE_MICROSTRUCTURE=true
FORMAL_MONITOR_SCALP_NO_SOURCE_HIGH_EDGE=30
FORMAL_MONITOR_SCALP_NO_SOURCE_HIGH_EDGE_MIN_VOLUME_RATIO=0.9
FORMAL_MONITOR_SCALP_NO_SOURCE_MEDIUM_EDGE=26
FORMAL_MONITOR_SCALP_NO_SOURCE_MEDIUM_EDGE_MIN_VOLUME_RATIO=1.2
FORMAL_MONITOR_SCALP_NO_SOURCE_MIN_CLOSED_MOVE_PERCENT=0.18
FORMAL_MONITOR_SCALP_NO_SOURCE_MAX_LIVE_MOVE_PERCENT=0.18
FORMAL_MONITOR_SCALP_NO_SOURCE_MAX_CLOSED_MOVE_PERCENT=0.55
FORMAL_MONITOR_SCALP_CONFIRMATION_SCANS=1
FORMAL_MONITOR_OPPORTUNITY_HISTORY_MAX_ITEMS=1200
FORMAL_MONITOR_WATCHLIST_MAX_CANDIDATES=16
FORMAL_MONITOR_WATCHLIST_MIN_SCORE=74
FORMAL_MONITOR_WATCHLIST_MIN_EDGE=16
FORMAL_MONITOR_EDGE_CONTRADICTION=25
FORMAL_MONITOR_MAX_CHASE_24H_PERCENT=18
FORMAL_MONITOR_MAX_LONG_CHASE_24H_PERCENT=12
FORMAL_MONITOR_MAX_SHORT_CHASE_24H_PERCENT=18
FORMAL_MONITOR_MAX_ATR_PERCENT=2
FORMAL_MONITOR_MAX_SPREAD_PERCENT=0.08
FORMAL_MONITOR_MIN_NET_TARGET_PERCENT=0.12
FORMAL_MONITOR_MIN_REWARD_RISK=1.15
FORMAL_MONITOR_AI_MIN_CONFIDENCE=0.75
FORMAL_MONITOR_WATCH_ENABLED=true
FORMAL_MONITOR_WATCH_MAX_CANDIDATES=12
FORMAL_MONITOR_WATCH_MAX_FAILURES=3
FORMAL_MONITOR_WATCH_MIN_SCORE=68
FORMAL_MONITOR_WATCH_MIN_EDGE=18
FORMAL_MONITOR_OBSERVATION_LOG_LIMIT=3
FORMAL_MONITOR_SHADOW_PROFILES=control:minEdge=25,minScore=72,targetAtrFraction=0.85,stopAtrFraction=0.62,minRewardRisk=1.15;frequency_probe:minEdge=22,minScore=69,targetAtrFraction=0.85,stopAtrFraction=0.62,minRewardRisk=1.05
FORMAL_MONITOR_SHADOW_AI_ENABLED=false
FORMAL_MONITOR_SHADOW_AI_MAX_CANDIDATES=2

# Feishu notifications. Set FEISHU_MESSAGE_MODE to webhook or app.
# webhook: create an incoming webhook in Feishu/Lark group bot settings.
# app: use a self-built application and send through the Feishu IM API.
# app mode supports both:
# 1) direct message to a user: FEISHU_RECEIVE_ID_TYPE=open_id / user_id / email
# 2) message to a group: FEISHU_RECEIVE_ID_TYPE=chat_id
FEISHU_ENABLED=false
FEISHU_MESSAGE_MODE=webhook
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_RECEIVE_ID_TYPE=open_id
FEISHU_RECEIVE_ID=
FEISHU_API_BASE_URL=https://open.feishu.cn/open-apis
FEISHU_MARKET_SIGNAL_LEVELS=formal
FEISHU_LIFECYCLE_EVENTS=open_signal,entry,close
FEISHU_HIGH_PRECISION_ONLY=true
FEISHU_HIGH_PRECISION_SCORE=84
FEISHU_HIGH_PRECISION_VOLUME_RATIO=1.5
FEISHU_HIGH_PRECISION_VOLUME_SCORE=74
FEISHU_NOTIFY_COOLDOWN_MINUTES=60
FEISHU_DRY_RUN=false
